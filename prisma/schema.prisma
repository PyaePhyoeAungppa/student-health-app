// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model School {
  id        String   @id @default(cuid())
  name      String
  province  String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  students  Student[]
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("SCHOOL_STAFF") // "SYSTEM_ADMIN" | "COMPANY_STAFF" | "SCHOOL_STAFF"
  fullName     String?
  email        String?
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Student {
  id                String       @id @default(cuid())
  studentId         String       @unique
  orderNumber       Int
  class             String
  gender            String
  firstName         String
  surName           String
  dob               DateTime
  schoolId          String
  school            School       @relation(fields: [schoolId], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  healthRecords     HealthRecord[]
}

model HealthRecord {
  id                  String     @id @default(cuid())
  studentId           String
  student             Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  recordedAt          DateTime   @default(now())
  academicYear        String?
  underlyingDisease   String?
  drugAllergy         String?
  bloodType           String     @default("UNKNOWN") // "A" | "B" | "AB" | "O" | "UNKNOWN"
  weight              Float?
  height              Float?
  bmi                 Float?
  hearingTest         String     @default("NORMAL") // "NORMAL" | "ABNORMAL"
  bodyExamination     String?
  visionPrescription  String?
  colorBlindness      String     @default("NORMAL") // "NORMAL" | "ABNORMAL"
  xRayResult          String?
  additionalNotes     String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}
